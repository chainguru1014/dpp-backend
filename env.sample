PORT=5052
DATABASE=mongodb://127.0.0.1:27017/dpp
API_BASE_URL=https://api.innosynch.com/
REMOTE_FILES_BASE_URL=https://api.innosynch.com/files
# Public app / product-page URL embedded in QR codes
PUBLIC_APP_URL=https://dpp.innosynch.com
# Public app URL embedded in transfer links / emails
PUBLIC_WEB_APP_URL=https://dpp.innosynch.com
# OpenAI — powers the Chat assistant and AI Recommendations (server-side only).
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o-mini

# --- Auth (JWT + passwordless sign-in) ---
# Required. The server refuses to start without this — no insecure default.
JWT_SECRET=
JWT_EXPIRES_IN=1d

# SMTP — used for transfer invite emails and email OTP codes.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Google Sign-In — POST /auth/google verifies the ID token's audience against
# whichever of these are set (web/Android/iOS OAuth client ids).
GOOGLE_WEB_CLIENT_ID=
GOOGLE_ANDROID_CLIENT_ID=
GOOGLE_IOS_CLIENT_ID=

# Apple Sign-In — POST /auth/apple verifies the identityToken's audience
# against APPLE_CLIENT_ID (comma-separate multiple service/app ids if needed).
# APPLE_TEAM_ID/APPLE_KEY_ID/APPLE_PRIVATE_KEY are only needed if this backend
# ever generates its own Apple client secret (e.g. for server-to-server calls).
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_CLIENT_ID=
APPLE_BUNDLE_ID=
APPLE_PRIVATE_KEY=
